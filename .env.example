# =============================================================================
# TLEF-CREATE — Development Environment Configuration
# =============================================================================
# Copy this file to .env before starting the application:
#   cp .env.example .env
#
# Most values below are standard local-dev defaults and work out of the box.
# Values marked [REQUIRED] must be filled in manually — they differ per developer.
# =============================================================================

# Server Configuration
PORT=8051
NODE_ENV=development
ADMIN_CWLS=faculty-user

# Database Configuration
# Uses the shared tlef-mongodb-docker container's root user (mongoadmin/secret).
# Root user lives in the `admin` db, so authSource=admin is required; the
# `/tlef-create` path selects the working database for this app.
MONGODB_URI=mongodb://mongoadmin:secret@localhost:27017/tlef-create?authSource=admin
REDIS_URL=redis://:tlef-redis-2024@localhost:6379
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=super-secret-dev-key

# Session Configuration
SESSION_SECRET=dev-session-secret-change-in-production

# Frontend Configuration (for development CORS)
FRONTEND_URL=http://localhost:8092
VITE_API_URL=http://localhost:8051

# SAML Configuration
# In development, uses docker-simple-saml as the Identity Provider (IdP).
# In production/staging, switches to UBC Shibboleth automatically via NODE_ENV.
SAML_AVAILABLE=true
SAML_ENVIRONMENT=LOCAL

# Service Provider Configuration
SAML_ISSUER=https://tlef-create
SAML_CALLBACK_URL=http://localhost:8051/api/create/auth/saml/callback
SAML_LOGOUT_CALLBACK_URL=http://localhost:8051/api/create/auth/logout/callback

# IdP Endpoints (docker-simple-saml local dev defaults)
SAML_ENTRY_POINT=http://localhost:8080/simplesaml/saml2/idp/SSOService.php
SAML_LOGOUT_URL=http://localhost:8080/simplesaml/saml2/idp/SingleLogoutService.php
SAML_METADATA_URL=http://localhost:8080/simplesaml/saml2/idp/metadata.php

# Certificate Path (points to docker-simple-saml's auto-generated cert)
SAML_CERT_PATH=../docker-simple-saml/cert/server.crt

# File Upload Configuration
UPLOAD_DIR=./routes/create/uploads
MAX_FILE_SIZE=104857600

# URL Domain Allowlist (JSON array of allowed domains)
ALLOWED_DOMAINS=["ubc.ca","wikipedia.org"]

# AI Services — Ollama (local, no key needed)
OLLAMA_ENDPOINT=http://localhost:11434
OLLAMA_MODEL=llama3.1:8b

# LLM Provider Configuration
# Set LLM_PROVIDER=ollama to use local Ollama (no API key needed).
# Set LLM_PROVIDER=openai to use OpenAI or a LiteLLM proxy.
LLM_PROVIDER=ollama
LLM_API_ENDPOINT=http://localhost:11434/v1

# [REQUIRED] OpenAI API Key — only needed if LLM_PROVIDER=openai
# Get your key from https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-your-openai-api-key-here
OPENAI_MODEL=gpt-4o-mini

# Canvas LMS Integration (optional — only if canvas-lms-docker is running)
CANVAS_BASE_URL=http://localhost
CANVAS_CLIENT_ID=10000000000001
# [REQUIRED if using Canvas] Copy from Canvas Developer Key in your local Canvas instance
CANVAS_CLIENT_SECRET=your-canvas-client-secret-here
CANVAS_REDIRECT_URI=http://localhost:8051/api/create/canvas/oauth/callback
LTI_CLIENT_ID=10000000000002
LTI_PUBLIC_URL=http://localhost:7737

# Future Services (not yet active)
RAG_SERVICE_URL=http://localhost:8000
DOCUMENT_PARSER_URL=http://localhost:8001
